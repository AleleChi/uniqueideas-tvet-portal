# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP configuration for Federal Trainee Admission notifications.
# Configure SMTP_USER with your full sender email (e.g. Gmail).
# Configure SMTP_PASS with your secure app password.
SMTP_USER="uniqueideasproject@gmail.com"
SMTP_PASS=""

# Database Configuration
# Set the connection string of your PostgreSQL server. 
# Leaving this empty triggers the secure filesystem JSON fallback storage (fully compatible).
DATABASE_URL=

# JSON Web Token Secret
# Key used to sign and verify secure session authorization cookie structures.
# Falls back to a default token string if left empty.
JWT_SECRET=

# Resend Email Configuration
# Secure API Key for dispatching emails through Resend service.
RESEND_API_KEY=

# Cloudinary Storage Configuration
# Used to persist generated PDF documents (Admission, Acceptance, Enrollment, Certificates).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Environment and Dev Settings
# Set to 'production' on live cloud nodes to enable strict CSRF session guards.
NODE_ENV=development
DISABLE_HMR=true

